# ══════════════════════════════════════════════════════════
# AI Test Engineer Agent — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git (it contains secrets)
# ══════════════════════════════════════════════════════════

# ── App Settings ─────────────────────────────────────────
APP_NAME=AI Test Engineer Agent
APP_VERSION=1.0.0
DEBUG=True

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_test_engineer

# ── LLM Provider (choose one: gemini, groq, ollama) ─────
LLM_PROVIDER=gemini

# Gemini (Free) — Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (Free) — Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (Local) — Install from: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Security ─────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── CORS (Frontend URLs allowed to call API) ─────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
